{
  "name": "tedemehrtens.de",
  "private": true,
  "scripts": {
    "lint:js": "eslint assets/js/",
    "lint:html": "htmlhint '_includes/**/*.html' '_layouts/**/*.html' '*.html'",
    "lint:md": "markdownlint-cli2 '_posts/**/*.md' 'about.md' 'impressum.md'",
    "lint:html-site": "htmlhint '_site/**/*.html' --config .htmlhintrc-site",
    "lint": "npm run lint:js && npm run lint:html && npm run lint:md"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "htmlhint": "^1.1.4",
    "markdownlint-cli2": "^0.21.0"
  }
}
