# Security headers for all routes
# Note: Vary: Accept-Encoding is intentionally omitted — Cloudflare adds it
# automatically when applying gzip/Brotli compression. Setting it manually
# here would signal to Cloudflare that the origin handles encoding itself,
# which disables its automatic compression.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' {{ site.theme_csp_hash }}; style-src 'self'; img-src 'self' data:; font-src 'self'; frame-src https://www.youtube-nocookie.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

# Versioned assets: 1 year immutable (safe — cache-busted via ?v= query param)
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# Images: 1 year (rename file to bust cache)
/assets/img/*
  Cache-Control: public, max-age=31536000

# Fonts (if self-hosted in future): 1 year immutable
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Feed: 1 hour
/feed.xml
  Cache-Control: public, max-age=3600
